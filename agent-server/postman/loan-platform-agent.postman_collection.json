{
  "info": {
    "name": "Loan Platform Agent API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the agent bootstrap flow, agent run endpoint, and loan platform API smoke tests."
  },
  "variable": [
    { "key": "agentBaseUrl", "value": "http://localhost:4000" },
    { "key": "apiBaseUrl", "value": "http://localhost:3000" },
    { "key": "swaggerUrl", "value": "http://localhost:3000/openapi.yaml" }
  ],
  "item": [
    {
      "name": "Agent Bootstrap",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{agentBaseUrl}}/qa/bootstrap"
      }
    },
    {
      "name": "Run Agent",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Test the full loan workflow and explain failures simply\",\n  \"apiBaseUrl\": \"{{apiBaseUrl}}\",\n  \"swaggerUrl\": \"{{swaggerUrl}}\",\n  \"maxRoutes\": 4,\n  \"conversationMode\": true\n}"
        },
        "url": "{{agentBaseUrl}}/qa/run"
      }
    },
    {
      "name": "Loan API Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{apiBaseUrl}}/health"
      }
    },
    {
      "name": "Loan API Swagger",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{swaggerUrl}}"
      }
    }
  ]
}
