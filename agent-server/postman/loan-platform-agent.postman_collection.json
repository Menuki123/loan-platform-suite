{
  "info": {
    "name": "Loan Platform Agent Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the System Functional Evaluation Agent demo."
  },
  "item": [
    {
      "name": "Health - API Server",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{apiBaseUrl}}/health",
          "host": ["{{apiBaseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Health - Agent Server",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{agentBaseUrl}}/health",
          "host": ["{{agentBaseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Bootstrap Conversation",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{agentBaseUrl}}/qa/bootstrap",
          "host": ["{{agentBaseUrl}}"],
          "path": ["qa", "bootstrap"]
        }
      }
    },
    {
      "name": "Run QA Agent",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Validate the full loan application workflow and explain failures simply\",\n  \"apiBaseUrl\": \"{{apiBaseUrl}}\",\n  \"swaggerUrl\": \"{{swaggerUrl}}\",\n  \"maxRoutes\": 4,\n  \"responseMode\": \"table\"\n}"
        },
        "url": {
          "raw": "{{agentBaseUrl}}/qa/run",
          "host": ["{{agentBaseUrl}}"],
          "path": ["qa", "run"]
        }
      }
    }
  ],
  "variable": [
    { "key": "apiBaseUrl", "value": "http://localhost:3000" },
    { "key": "agentBaseUrl", "value": "http://localhost:4000" },
    { "key": "swaggerUrl", "value": "http://localhost:3000/openapi.yaml" }
  ]
}
