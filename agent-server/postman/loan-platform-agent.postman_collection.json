{
  "info": {
    "name": "Loan Platform AI Agent Collection",
    "description": "Postman collection for the MCP-inspired AI agent server and LOS API integration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Agent Bootstrap",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/qa/bootstrap",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["qa", "bootstrap"]
        }
      }
    },
    {
      "name": "MCP Tools",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/mcp/tools",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["mcp", "tools"]
        }
      }
    },
    {
      "name": "Prompt Templates",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:4000/prompts/templates",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["prompts", "templates"]
        }
      }
    },
    {
      "name": "Run Agent",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Validate the LOS application form and explain failures clearly\",\n  \"apiBaseUrl\": \"http://localhost:3000\",\n  \"swaggerUrl\": \"http://localhost:3000/openapi.yaml\",\n  \"maxRoutes\": 4\n}"
        },
        "url": {
          "raw": "http://localhost:4000/qa/run",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["qa", "run"]
        }
      }
    }
  ]
}
